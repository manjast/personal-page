---
interface Props {
  title: string;
  description: string;
  primary: { href: string; label: string };
  secondary?: { href: string; label: string };
}

const { title, description, primary, secondary } = Astro.props;
---

<section class="section-space">
  <div class="shell">
    <div class="panel panel-dark relative overflow-hidden px-6 py-10 text-stone-100 sm:px-10">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(245,245,244,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(245,245,244,0.06)_1px,transparent_1px)] bg-[size:20px_20px] opacity-70"></div>
      <div class="relative flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-4">
          <p class="eyebrow text-stone-400">Project inquiry</p>
          <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h2>
          <p class="max-w-2xl text-base leading-8 text-stone-300">{description}</p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a class="button-primary bg-white text-stone-950 hover:bg-stone-200" href={primary.href}>
            {primary.label}
          </a>
          {secondary && (
            <a class="button-secondary-dark" href={secondary.href}>
              {secondary.label}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
