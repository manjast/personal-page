---
import type { CollectionEntry } from 'astro:content';
import { getSiteContent } from '../config/site';
import { caseStudyPath, type Locale } from '../i18n/routing';

interface Props {
  entry: CollectionEntry<'case-studies'>;
  locale?: Locale;
}

const { entry, locale = 'en' } = Astro.props;
const labels = getSiteContent(locale).ui.caseStudyCard;
const href = caseStudyPath(locale, entry.data.routeSlug);
---

<article class="panel panel-light flex h-full flex-col p-6 hover:-translate-y-0.5 hover:border-[color:rgba(143,73,47,0.35)]">
  <div class="flex items-start gap-4">
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <p class="eyebrow">{entry.data.organization}</p>
        <span class="eyebrow whitespace-nowrap">{labels.caseLabel} {String(entry.data.order).padStart(2, '0')}</span>
      </div>
      <h3
        class:list={[
          'mt-3 text-2xl font-semibold tracking-tight text-[color:var(--ink)]',
          locale === 'sr' ? 'lg:min-h-[5.5rem] lg:max-w-[28ch]' : 'lg:min-h-[4.5rem] lg:max-w-[22ch]',
        ]}
      >
        <a class="transition hover:text-[color:var(--accent)]" href={href}>
          {entry.data.title}
        </a>
      </h3>
    </div>
  </div>

  <p class="mt-5 text-sm leading-7 muted-copy">{entry.data.summary}</p>

  <dl class="mt-6 space-y-3 text-sm">
    <div>
      <dt class="font-semibold text-[color:var(--ink)]">{labels.contextLabel}</dt>
      <dd class="mt-1 muted-copy">{entry.data.workContext}</dd>
    </div>
    <div>
      <dt class="font-semibold text-[color:var(--ink)]">{entry.data.signalLabel ?? labels.outcomeLabel}</dt>
      <dd class="mt-1 muted-copy">{entry.data.outcome}</dd>
    </div>
  </dl>

  <div class="mt-6 flex flex-wrap gap-2 pb-4">
    {
      entry.data.technologies.map((technology) => (
        <span class="rounded-lg border border-[color:var(--rule)] bg-white/45 px-3 py-1 text-[0.75rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">{technology}</span>
      ))
    }
  </div>

  <div class="mt-auto border-t border-[color:var(--rule)] pt-4">
    <a class="inline-flex min-h-[44px] items-center py-2 text-sm font-semibold text-[color:var(--ink)] transition hover:text-[color:var(--accent)]" href={href}>
      {labels.readLabel} →
    </a>
  </div>
</article>
