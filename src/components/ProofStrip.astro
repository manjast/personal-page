---
interface Item {
  eyebrow: string;
  value: string;
  label: string;
  copy: string;
}

interface Props {
  items: readonly Item[];
}

const { items } = Astro.props;
---

<section class="pb-4 sm:pb-6">
  <div class="shell">
    <div class="grid gap-4 md:grid-cols-3">
      {
        items.map((item) => (
          <article class="panel panel-light h-full px-5 py-5 sm:px-6 sm:py-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">{item.eyebrow}</p>
            <p class="mt-3 text-3xl font-semibold leading-none tracking-tight text-[color:var(--ink)] lg:text-4xl">{item.value}</p>
            <p class="mt-1 text-base font-medium text-[color:var(--ink-soft)]">{item.label}</p>
            <p class="mt-3 text-sm leading-7 muted-copy">{item.copy}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
