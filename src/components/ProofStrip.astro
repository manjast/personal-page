---
interface Item {
  eyebrow: string;
  value: string;
  label: string;
  copy: string;
}

interface Props {
  items: readonly Item[];
}

const { items } = Astro.props;
---

<section class="pb-4 sm:pb-5">
  <div class="shell">
    <div class="grid gap-4 md:grid-cols-3">
        {
          items.map((item) => (
            <article class="panel panel-light h-full px-5 py-5 sm:px-6 sm:py-5">
              <p class="eyebrow">{item.eyebrow}</p>
              <p class="mt-3 text-4xl font-semibold leading-none tracking-tight text-stone-950">{item.value}</p>
              <p class="mt-1 text-base font-medium text-stone-800">{item.label}</p>
              <p class="mt-2 text-sm leading-7 text-stone-600">{item.copy}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
