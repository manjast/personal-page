---
import { getSiteContent } from '../config/site';
import type { Locale } from '../i18n/routing';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const { siteConfig, ui } = getSiteContent(locale);
const year = new Date().getFullYear();
---

<footer class="border-t-2 border-[color:var(--accent)] bg-[color:var(--dark)] text-stone-100">
  <div class="shell flex flex-col gap-8 py-10 sm:flex-row sm:items-end sm:justify-between">
    <div class="max-w-xl space-y-3">
      <div class="accent-bar"></div>
      <p class="text-base font-semibold tracking-tight text-stone-50">{siteConfig.name}</p>
      <p class="text-sm leading-7 text-stone-300">
        {ui.footerDescription}
      </p>
    </div>

    <div class="space-y-2 text-sm text-stone-400 sm:text-right">
      <a class="flex h-11 items-center transition hover:text-[color:var(--accent-strong)] sm:justify-end" href={`mailto:${siteConfig.email}`}>
        {siteConfig.email}
      </a>
      <a class="flex h-11 items-center transition hover:text-[color:var(--accent-strong)] sm:justify-end" href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer">
        LinkedIn
      </a>
      <a class="flex h-11 items-center transition hover:text-[color:var(--accent-strong)] sm:justify-end" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        GitHub
      </a>
      <p>© {year} {siteConfig.name}</p>
    </div>
  </div>
</footer>
