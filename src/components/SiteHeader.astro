---
import { getSiteContent } from '../config/site';
import {
  getAlternatePaths,
  localeMeta,
  localizedHref,
  stripLocalePrefix,
  type Locale,
} from '../i18n/routing';

interface Props {
  locale?: Locale;
  alternates?: Partial<Record<Locale | 'x-default', string>>;
}

const { locale = 'en', alternates } = Astro.props;
const pathname = Astro.url.pathname;
const content = getSiteContent(locale);
const { navigation, siteConfig } = content;
const alternatePaths = { ...getAlternatePaths(pathname), ...(alternates ?? {}) };

function isActive(href: string) {
  const currentBasePath = stripLocalePrefix(pathname);
  const targetBasePath = stripLocalePrefix(href);

  return targetBasePath === '/' ? currentBasePath === '/' : currentBasePath.startsWith(targetBasePath);
}
---

<header class="sticky top-0 z-50 border-b border-[color:var(--rule)] bg-[rgba(243,240,232,0.9)] backdrop-blur-sm">
  <div class="shell flex flex-col gap-1.5 py-3 sm:py-5 lg:flex-row lg:items-center lg:justify-between lg:gap-5">
    <a href={localizedHref(locale, '/')} class="group inline-flex min-h-[44px] min-w-0 flex-col justify-center gap-0.5">
      <span class="text-lg font-semibold tracking-tight text-[color:var(--ink)]">{siteConfig.name}</span>
      <span
        class="site-tagline hidden uppercase text-[color:var(--muted-soft)] sm:block"
        style="font-family: 'IBM Plex Mono', ui-monospace, monospace;"
      >
        {siteConfig.tagline}
      </span>
    </a>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between lg:shrink-0">
      <nav
        aria-label={content.ui.navAriaLabel}
        class="site-nav flex flex-wrap items-center gap-x-3 gap-y-1 font-medium uppercase text-[color:var(--muted)] sm:gap-x-5 lg:flex-nowrap"
        style="font-family: 'IBM Plex Mono', ui-monospace, monospace;"
      >
        {
          navigation.map((item) => (
            <a
              class:list={[
                'inline-flex min-h-[44px] items-center px-2 py-2 transition hover:text-[color:var(--ink)] sm:px-1',
                isActive(item.href) && 'text-[color:var(--accent)]',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              href={localizedHref(locale, item.href)}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div
        aria-label={content.ui.languageSwitcherLabel}
        class="language-switcher flex w-fit items-center rounded-xl border border-[color:var(--rule)] bg-white/60 p-1 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[color:var(--muted)]"
      >
        {
          (['en', 'sr'] as const).map((targetLocale) => (
            <a
              class:list={[
                'inline-flex min-h-[44px] items-center rounded-lg px-2.5 transition hover:text-[color:var(--ink)]',
                locale === targetLocale && 'bg-[color:var(--ink)] text-[color:var(--canvas)] hover:text-[color:var(--canvas)]',
              ]}
              href={alternatePaths[targetLocale]}
              hreflang={localeMeta[targetLocale].hreflang}
              lang={localeMeta[targetLocale].lang}
              aria-current={locale === targetLocale ? 'true' : undefined}
              aria-label={`${content.ui.switchLanguageLabel}: ${localeMeta[targetLocale].label}`}
            >
              <span class="sm:hidden">{localeMeta[targetLocale].shortLabel}</span>
              <span class="hidden sm:inline">{localeMeta[targetLocale].label}</span>
            </a>
          ))
        }
      </div>
      <a class="button-primary hidden xl:inline-flex" href={localizedHref(locale, siteConfig.heroPrimaryCta.href)}>
        {siteConfig.heroPrimaryCta.label}
      </a>
    </div>
  </div>
</header>
