---
import { navigation, siteConfig } from '../config/site';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-[color:var(--rule)] bg-[rgba(243,240,232,0.9)] backdrop-blur-sm">
  <div class="shell flex flex-col gap-1.5 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-3 sm:py-5">
    <a href="/" class="group inline-flex flex-col gap-0.5">
      <span class="text-lg font-semibold tracking-tight text-[color:var(--ink)]">{siteConfig.name}</span>
      <span
        class="site-tagline uppercase text-[color:var(--muted-soft)]"
        style="font-family: 'IBM Plex Mono', ui-monospace, monospace;"
      >
        {siteConfig.tagline}
      </span>
    </a>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <nav
        aria-label="Primary"
        class="site-nav flex items-center gap-x-3 font-medium uppercase text-[color:var(--muted)] sm:flex-wrap sm:gap-x-5 sm:gap-y-1"
        style="font-family: 'IBM Plex Mono', ui-monospace, monospace;"
      >
        {
          navigation.map((item) => (
            <a
              class:list={[
                'inline-flex min-h-[44px] items-center py-2 transition hover:text-[color:var(--ink)] sm:px-1',
                isActive(item.href) && 'text-[color:var(--accent)]',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a class="button-primary hidden sm:inline-flex" href={siteConfig.heroPrimaryCta.href}>
        {siteConfig.heroPrimaryCta.label}
      </a>
    </div>
  </div>
</header>
