---
import '../styles/global.css';
import { siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  pageSchema?: Record<string, unknown>[];
}

const {
  title = siteConfig.defaultTitle,
  description = siteConfig.defaultDescription,
  pathname = Astro.url.pathname,
  image = '/og-default.png',
  ogType = 'website',
  noindex = false,
  pageSchema,
} = Astro.props;

const pageTitle = title === siteConfig.defaultTitle ? title : `${title} | ${siteConfig.defaultTitle}`;
const canonical = new URL(pathname, siteConfig.siteUrl).toString();
const socialImage = new URL(image, siteConfig.siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteConfig.siteUrl}/#person`,
      name: siteConfig.name,
      url: siteConfig.siteUrl,
      email: siteConfig.email,
      sameAs: [siteConfig.linkedinUrl, siteConfig.githubUrl],
      jobTitle: 'AI Systems Builder',
      description: siteConfig.defaultDescription,
    },
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.siteUrl}/#website`,
      url: siteConfig.siteUrl,
      name: siteConfig.name,
      description: siteConfig.defaultDescription,
      author: { '@id': `${siteConfig.siteUrl}/#person` },
    },
    ...(pageSchema ?? []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f0e8" />
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-latin-var-v23.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-condensed-latin-600-v15.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" sizes="16x16 32x32 48x48" />
    <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.defaultTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    {ogType === 'article' && <meta property="article:author" content={siteConfig.linkedinUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script
      is:inline
      data-goatcounter="https://stefanmanja.goatcounter.com/count"
      async
      src="https://gc.zgo.at/count.v5.js"
      integrity="sha384-atnOLvQb9t+jTSipvd75X2yginT4PjVbqDdlJAmxMm+wYElFmeR6EmLP5bYeoRVQ"
      crossorigin="anonymous"
    ></script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
