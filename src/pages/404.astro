---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout pathname="/404" title="Page not found" noindex={true}>
  <SiteHeader />

  <main class="section-space">
    <div class="shell">
      <div class="panel panel-light max-w-3xl p-8 sm:p-10">
        <p class="eyebrow">404</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-stone-950">That page does not exist.</h1>
        <p class="mt-4 text-base leading-8 text-stone-600">
          The best path back is usually the homepage, the selected work page, or the contact page.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href="/">Go home</a>
          <a class="button-secondary" href="/work">View selected work</a>
        </div>
      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>
