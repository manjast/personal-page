---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { contactExpectations, fitGuidance, siteConfig } from '../config/site';

const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID;
const formAction = formId ? `https://formspree.io/f/${formId}` : undefined;
const formSuccessPath = '/contact/sent/';
---

<BaseLayout
  locale="en"
  pathname="/contact/"
  title="Review an Internal AI Workflow"
  description="Send an internal AI workflow for a focused review with Stefan Manja."
  pageSchema={[
    {
      '@type': 'ContactPage',
      '@id': `${siteConfig.siteUrl}/contact/#webpage`,
      url: `${siteConfig.siteUrl}/contact/`,
      name: 'Review an Internal AI Workflow | Stefan Manja',
      author: { '@id': `${siteConfig.siteUrl}/#person` },
      inLanguage: 'en',
    },
  ]}
>
  <SiteHeader />

  <main id="main">
    <section class="section-space">
      <div class="shell">
        <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div class="space-y-6">
            <div class="page-lead">
              <div class="flex flex-wrap items-center gap-3">
               <span class="section-marker">01 / contact</span>
                 <p class="eyebrow">Workflow review</p>
              </div>
              <h1 class="page-title">
                Start with the workflow.
              </h1>
                <p class="text-base leading-8 muted-copy">
                 I take on a small number of projects where the operating problem, owner, and boundaries are concrete enough
                 for the work to be useful. You do not need the solution shaped yet; the useful starting point is the
                 workflow and what needs to become easier, faster, safer, or more reviewable. Workflow conversations are
                 handled discreetly, and internal context is treated with care.
               </p>
            </div>

            <div class="panel panel-light p-6">
              <div class="accent-bar"></div>
              <p class="text-sm font-semibold text-[color:var(--ink)]">Direct email</p>
              <a
                id="contact-email-link"
                class="mt-3 inline-flex h-11 items-center text-base font-semibold text-[color:var(--ink)] transition hover:text-[color:var(--accent)]"
                href={`mailto:${siteConfig.email}`}
              >
                {siteConfig.email}
              </a>
              <p class="mt-4 text-sm leading-7 muted-copy">{contactExpectations.responseTime}</p>
              <p class="mt-2 text-sm leading-7 muted-copy">{contactExpectations.fitNote}</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-1">
              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Useful first emails</p>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                  <li>The workflow and users are easy to describe.</li>
                  <li>You can describe whether this is a new build, an existing prototype, or a workflow decision that needs review.</li>
                  <li>There is already an owner, a current stage, and a constraint that will matter in practice.</li>
                </ul>
              </article>

              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Usually too early or not the right shape</p>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                  {fitGuidance.notFit.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            </div>
          </div>

          {
            formAction ? (
              <div class="panel panel-light p-6 sm:p-8">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Workflow review</p>
                <p class="mt-3 text-sm leading-7 muted-copy">Enough context for a first workflow review.</p>

                <form
                  id="contact-form"
                  class="mt-8 space-y-6"
                  method="POST"
                  action={formAction}
                  data-success-path={formSuccessPath}
                  data-error-message="The message could not be sent right now. Please try again or email me directly."
                >
                  <input type="hidden" name="subject" value="Workflow review from stefanmanja.com" />
                  <div class="absolute -left-[9999px] h-0 w-0 overflow-hidden opacity-0" aria-hidden="true">
                    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
                  </div>
                  <div class="grid gap-6 sm:grid-cols-2">
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Name
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="name" autocomplete="name" required />
                    </label>

                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Work email
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="email" name="email" autocomplete="email" required />
                    </label>
                  </div>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    Company or team
                    <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="company" autocomplete="organization" />
                  </label>

                  <div>
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="use-case">
                      What are you trying to build or improve?
                    </label>
                    <textarea
                      id="use-case"
                      class="mt-2.5 min-h-[7.5rem] w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]"
                      name="use_case"
                      aria-describedby="use-case-hint"
                      required
                    ></textarea>
                    <p id="use-case-hint" class="mt-2 text-xs leading-5 muted-copy">One or two sentences are enough.</p>
                  </div>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="primary-concern">
                    Primary concern
                    <select id="primary-concern" class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="primary_concern" required>
                      <option value="">Select one</option>
                      <option value="worth-building">Deciding whether this is worth building</option>
                      <option value="prototype-hardening">Prototype exists but needs hardening</option>
                      <option value="assistant-readiness">Internal assistant / RAG system needs readiness review</option>
                      <option value="decision-support">Analyst workflow needs decision-support</option>
                      <option value="second-opinion">Need second opinion on vendor or architecture direction</option>
                      <option value="other">Other</option>
                    </select>
                  </label>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="current-stage">
                    Current stage
                    <select id="current-stage" class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="current_stage" required>
                      <option value="">Select one</option>
                      <option value="exploring">Workflow defined, exploring approach</option>
                      <option value="prototype">Prototype exists</option>
                      <option value="hardening">Needs production hardening</option>
                      <option value="replace-rescue">Replacing or rescuing an existing workflow</option>
                    </select>
                  </label>

                  <fieldset class="space-y-3">
                    <legend class="text-sm font-medium text-[color:var(--ink-soft)]">Known constraints</legend>
                    <div class="grid gap-3 sm:grid-cols-2">
                      {
                        [
                          'Data or access restrictions',
                          'Human review required',
                          'Cost or usage concern',
                          'Compliance or governance concern',
                          'Existing prototype or vendor',
                          'Timeline pressure',
                          'Internal handoff required',
                        ].map((constraint) => (
                          <label class="flex min-h-[44px] items-start gap-3 rounded-2xl border border-[color:var(--rule)] bg-white/65 px-4 py-3 text-sm leading-6 text-[color:var(--ink-soft)]">
                            <input
                              class="mt-1 h-4 w-4 rounded border-[color:var(--rule)] text-[color:var(--accent)] focus:ring-[color:var(--accent)]"
                              type="checkbox"
                              name="constraints"
                              value={constraint}
                            />
                            <span>{constraint}</span>
                          </label>
                        ))
                      }
                    </div>
                  </fieldset>

                  <div>
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="context">
                      Relevant context
                    </label>
                    <textarea
                      id="context"
                      class="mt-2.5 min-h-40 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]"
                      name="context"
                      aria-describedby="context-hint"
                      required
                    ></textarea>
                    <p id="context-hint" class="mt-2 text-xs leading-5 muted-copy">
                      Current tooling, team size, timeline pressure, or trust requirements - whatever is already clear.
                    </p>
                  </div>

                  <button class="button-primary" type="submit">
                    Send workflow for review
                  </button>
                  <p class="text-sm leading-7 muted-copy">
                    Submissions are sent via Formspree and used only to reply to your message.
                  </p>
                  <p id="contact-form-status" class="text-sm leading-7 text-[color:var(--accent)]" hidden aria-live="polite"></p>
                </form>
                <div class="mt-8 border-t border-[color:var(--rule)] pt-6">
                  <p class="text-sm font-semibold text-[color:var(--ink)]">What happens next</p>
                  <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                    <li>I review the workflow, current stage, and constraints.</li>
                    <li>If it looks like a fit, I reply within 3 business days.</li>
                    <li>If useful, I point to the likely next path: build, harden, simplify, stop, or a scoped advisory conversation.</li>
                    <li>If it is not the right shape, I will usually say that directly.</li>
                  </ul>
                </div>
              </div>
            ) : (
              <div class="panel panel-dark p-6 sm:p-8 lg:sticky lg:top-28">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-stone-50">What to include in a workflow review</p>
                <p class="mt-3 text-sm leading-7 text-stone-300">{contactExpectations.emailPrompt}</p>
                <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-stone-300 marker:text-stone-500">
                  <li>The workflow and who uses it today</li>
                  <li>The primary concern: feasibility, hardening, assistant readiness, decision-support, or second opinion</li>
                  <li>What would need to be trustworthy for the system to be useful</li>
                  <li>Any timeline, hosting, identity, or compliance constraints that already matter</li>
                </ul>
                <a class="button-primary-invert mt-8" href={`mailto:${siteConfig.email}?subject=Workflow review`}>
                  Email workflow outline
                </a>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
  <script is:inline>
    const contactForm = document.getElementById('contact-form');
    const contactFormStatus = document.getElementById('contact-form-status');

    document.getElementById('contact-email-link')?.addEventListener('click', function () {
      if (window.goatcounter && window.goatcounter.count) {
        window.goatcounter.count({ path: 'contact-email-click', title: 'Contact: Email Click', event: true });
      }
    });

    if (contactForm instanceof HTMLFormElement) {
      contactForm.addEventListener('submit', async function (event) {
        event.preventDefault();

        if (window.goatcounter && window.goatcounter.count) {
          window.goatcounter.count({ path: 'contact-form-submit', title: 'Contact: Form Submit', event: true });
        }

        const submitButton = contactForm.querySelector('button[type="submit"]');
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
          submitButton.setAttribute('aria-busy', 'true');
        }

        if (contactFormStatus instanceof HTMLElement) {
          contactFormStatus.hidden = true;
          contactFormStatus.textContent = '';
        }

        try {
          const response = await fetch(contactForm.action, {
            method: contactForm.method,
            body: new FormData(contactForm),
            headers: { Accept: 'application/json' },
          });

          if (!response.ok) {
            throw new Error(contactForm.dataset.errorMessage || 'Submission failed');
          }

          const successPath = contactForm.dataset.successPath;
          if (successPath) {
            window.location.assign(successPath);
          }
        } catch (error) {
          if (contactFormStatus instanceof HTMLElement) {
            contactFormStatus.textContent =
              error instanceof Error && error.message
                ? error.message
                : 'The message could not be sent right now. Please try again or email me directly.';
            contactFormStatus.hidden = false;
          }

          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
            submitButton.removeAttribute('aria-busy');
          }
        }
      });
    }
  </script>
</BaseLayout>
