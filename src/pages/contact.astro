---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { contactExpectations, fitGuidance, siteConfig } from '../config/site';

const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID;
const formAction = formId ? `https://formspree.io/f/${formId}` : undefined;
---

<BaseLayout
  pathname="/contact"
  title="Discuss an Internal AI Project"
  description="Start a project-based or advisory conversation about an internal AI workflow with Stefan Manja."
  pageSchema={[
    {
      '@type': 'ContactPage',
      '@id': `${siteConfig.siteUrl}/contact#webpage`,
      url: `${siteConfig.siteUrl}/contact`,
      name: 'Discuss an Internal AI Project | Stefan Manja',
      author: { '@id': 'https://stefanmanja.com/#person' },
    },
  ]}
>
  <SiteHeader />

  <main>
    <section class="section-space">
      <div class="shell">
        <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div class="space-y-6">
            <div class="page-lead">
              <div class="flex flex-wrap items-center gap-3">
                <span class="section-marker">01 / contact</span>
                <p class="eyebrow">Contact</p>
              </div>
              <h1 class="page-title">
                Project-based and advisory work.
              </h1>
              <p class="text-base leading-8 muted-copy">
                I take on project-based build, hardening, and advisory work around internal AI systems when the workflow, users,
                ownership, and constraints are concrete enough for the conversation to be useful.
              </p>
            </div>

            <div class="panel panel-light p-6">
              <div class="accent-bar"></div>
              <p class="text-sm font-semibold text-[color:var(--ink)]">Direct email</p>
              <a
                id="contact-email-link"
                class="mt-3 inline-flex text-base font-semibold text-[color:var(--ink)] transition hover:text-[color:var(--accent)]"
                href={`mailto:${siteConfig.email}`}
              >
                {siteConfig.email}
              </a>
              <p class="mt-4 text-sm leading-7 muted-copy">{contactExpectations.responseTime}</p>
              <p class="mt-2 text-sm leading-7 muted-copy">{contactExpectations.availability}</p>
              <p class="mt-2 text-sm leading-7 muted-copy">{contactExpectations.fitNote}</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-1">
              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Useful first emails</p>
                <ul class="mt-4 space-y-3 text-sm leading-7 text-[color:var(--ink-soft)]">
                  <li>• The workflow and users are easy to describe.</li>
                  <li>• You can say whether this is a new build, a hardening effort, or scoped advisory work.</li>
                  <li>• There is already an owner, a current stage, and a constraint that will matter in practice.</li>
                </ul>
              </article>

              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Usually not ready yet</p>
                <ul class="mt-4 space-y-3 text-sm leading-7 text-[color:var(--ink-soft)]">
                  {fitGuidance.notFit.map((item) => <li>• {item}</li>)}
                </ul>
              </article>
            </div>
          </div>

          {
            formAction ? (
              <div class="panel panel-light p-6 sm:p-8">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Project inquiry</p>
                <p class="mt-3 text-sm leading-7 muted-copy">
                  Light qualification only: enough context to decide whether the conversation should move forward.
                </p>

                <form id="contact-form" class="mt-8 space-y-6" method="POST" action={formAction}>
                  <input type="hidden" name="_subject" value="Project inquiry from stefanmanja.com" />
                  <div class="absolute -left-[9999px] h-0 w-0 overflow-hidden opacity-0" aria-hidden="true">
                    <label>Do not fill this in <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
                  </div>
                  <div class="grid gap-6 sm:grid-cols-2">
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Name
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="name" required />
                    </label>

                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Work email
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="email" name="email" required />
                    </label>
                  </div>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    Company or team
                    <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="company" />
                  </label>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    What are you trying to build or improve?
                    <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="use_case" required />
                  </label>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    Current stage
                    <select class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="current_stage" required>
                      <option value="">Select one</option>
                      <option value="exploring">Exploring options</option>
                      <option value="prototype">Prototype exists</option>
                      <option value="productionize">Needs production hardening</option>
                      <option value="replace-rescue">Replacing or rescuing an existing workflow</option>
                    </select>
                  </label>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    Relevant context
                    <textarea class="mt-2.5 min-h-40 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="context" required></textarea>
                  </label>

                  <button class="button-primary" type="submit">
                    Send project inquiry
                  </button>
                </form>
              </div>
            ) : (
              <div class="panel panel-dark p-6 sm:p-8 lg:sticky lg:top-28">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-stone-50">What to include in the first email</p>
                <p class="mt-3 text-sm leading-7 text-stone-300">{contactExpectations.emailPrompt}</p>
                <ul class="mt-6 space-y-3 text-sm leading-7 text-stone-300">
                  <li>• The workflow and who uses it today</li>
                  <li>• Whether this is a new build, a hardening pass, or scoped advisory work</li>
                  <li>• What would need to be trustworthy for the system to be useful</li>
                  <li>• Any timeline, hosting, identity, or compliance constraints that already matter</li>
                </ul>
                <a class="button-primary-invert mt-8" href={`mailto:${siteConfig.email}?subject=Project inquiry`}>
                  Email the project outline
                </a>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
  <script is:inline>
    document.getElementById('contact-email-link')?.addEventListener('click', function () {
      if (window.goatcounter && window.goatcounter.count) {
        window.goatcounter.count({ path: 'contact-email-click', title: 'Contact: Email Click', event: true });
      }
    });

    document.getElementById('contact-form')?.addEventListener('submit', function () {
      if (window.goatcounter && window.goatcounter.count) {
        window.goatcounter.count({ path: 'contact-form-submit', title: 'Contact: Form Submit', event: true });
      }
    });
  </script>
</BaseLayout>
