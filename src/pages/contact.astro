---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { contactExpectations, fitGuidance, siteConfig } from '../config/site';

const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID;
const formAction = formId ? `https://formspree.io/f/${formId}` : undefined;
---

<BaseLayout
  pathname="/contact"
  title="Contact"
  description="Start a project-based or advisory conversation about an internal AI workflow with Stefan Manja."
>
  <SiteHeader />

  <main>
    <section class="section-space">
      <div class="shell">
        <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div class="space-y-6">
            <div class="space-y-4">
              <div class="flex flex-wrap items-center gap-3">
                <span class="section-marker">01 / contact</span>
                <p class="eyebrow">Contact</p>
              </div>
              <h1 class="text-4xl font-semibold tracking-tight text-stone-950 sm:text-5xl">
                Project-based and advisory work.
              </h1>
              <p class="text-base leading-8 text-stone-600">
                I take on project-based build, hardening, and advisory work around internal AI systems when the workflow, users,
                ownership, and constraints are concrete enough for the conversation to be useful.
              </p>
            </div>

            <div class="panel panel-light p-6">
              <p class="text-sm font-semibold text-stone-950">Direct email</p>
              <a class="mt-3 inline-flex text-base font-semibold text-stone-950 transition hover:text-stone-700" href={`mailto:${siteConfig.email}`}>
                {siteConfig.email}
              </a>
              <p class="mt-4 text-sm leading-7 text-stone-600">{contactExpectations.responseTime}</p>
              <p class="mt-2 text-sm leading-7 text-stone-600">{contactExpectations.availability}</p>
              <p class="mt-2 text-sm leading-7 text-stone-600">{contactExpectations.fitNote}</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-1">
              <article class="panel panel-light p-6">
                <p class="text-sm font-semibold text-stone-950">Useful first emails</p>
                <ul class="mt-4 space-y-3 text-sm leading-7 text-stone-700">
                  <li>• The workflow and users are easy to describe.</li>
                  <li>• You can say whether this is a new build, a hardening effort, or scoped advisory work.</li>
                  <li>• There is already an owner, a current stage, and a constraint that will matter in practice.</li>
                </ul>
              </article>

              <article class="panel panel-light p-6">
                <p class="text-sm font-semibold text-stone-950">Usually not ready yet</p>
                <ul class="mt-4 space-y-3 text-sm leading-7 text-stone-700">
                  {fitGuidance.notFit.map((item) => <li>• {item}</li>)}
                </ul>
              </article>
            </div>
          </div>

          {
            formAction ? (
              <div class="panel panel-light p-6 sm:p-8">
                <p class="text-sm font-semibold text-stone-950">Project inquiry</p>
                <p class="mt-3 text-sm leading-7 text-stone-600">
                  Light qualification only: enough context to decide whether the conversation should move forward.
                </p>

                <form class="mt-8 space-y-5" method="POST" action={formAction}>
                  <input type="hidden" name="_subject" value="Project inquiry from stefanmanja.com" />
                  <div class="grid gap-5 sm:grid-cols-2">
                    <label class="block text-sm font-medium text-stone-800">
                      Name
                      <input class="mt-2 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" type="text" name="name" required />
                    </label>

                    <label class="block text-sm font-medium text-stone-800">
                      Work email
                      <input class="mt-2 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" type="email" name="email" required />
                    </label>
                  </div>

                  <label class="block text-sm font-medium text-stone-800">
                    Company or team
                    <input class="mt-2 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" type="text" name="company" />
                  </label>

                  <label class="block text-sm font-medium text-stone-800">
                    What are you trying to build or improve?
                    <input class="mt-2 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" type="text" name="use_case" required />
                  </label>

                  <label class="block text-sm font-medium text-stone-800">
                    Current stage
                    <select class="mt-2 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" name="current_stage" required>
                      <option value="">Select one</option>
                      <option value="exploring">Exploring options</option>
                      <option value="prototype">Prototype exists</option>
                      <option value="productionize">Needs production hardening</option>
                      <option value="replace-rescue">Replacing or rescuing an existing workflow</option>
                    </select>
                  </label>

                  <label class="block text-sm font-medium text-stone-800">
                    Relevant context
                    <textarea class="mt-2 min-h-40 w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-950 outline-none transition focus:border-stone-500" name="context" required></textarea>
                  </label>

                  <button class="button-primary" type="submit">
                    Send project inquiry
                  </button>
                </form>
              </div>
            ) : (
              <div class="panel panel-light p-6 sm:p-8 lg:sticky lg:top-8">
                <p class="text-sm font-semibold text-stone-950">What to include in the first email</p>
                <p class="mt-3 text-sm leading-7 text-stone-600">{contactExpectations.emailPrompt}</p>
                <ul class="mt-6 space-y-3 text-sm leading-7 text-stone-700">
                  <li>• The workflow and who uses it today</li>
                  <li>• Whether this is a new build, a hardening pass, or scoped advisory work</li>
                  <li>• What would need to be trustworthy for the system to be useful</li>
                  <li>• Any timeline, hosting, identity, or compliance constraints that already matter</li>
                </ul>
                <a class="button-primary mt-8" href={`mailto:${siteConfig.email}?subject=Project inquiry`}>
                  Email the project outline
                </a>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
