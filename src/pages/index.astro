---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import ProofStrip from '../components/ProofStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
import { fitGuidance, proofPoints, services, siteConfig } from '../config/site';

const caseStudies = (await getCollection('case-studies'))
  .sort((left, right) => left.data.order - right.data.order)
  .slice(0, 2);
---

<BaseLayout
  pathname="/"
  title="Internal AI Systems for Enterprise Workflows"
  description={siteConfig.defaultDescription}
  pageSchema={[
    {
      '@type': 'WebPage',
      '@id': `${siteConfig.siteUrl}/#webpage`,
      url: `${siteConfig.siteUrl}/`,
      name: 'Internal AI Systems for Enterprise Workflows | Stefan Manja',
      description: siteConfig.defaultDescription,
      author: { '@id': `${siteConfig.siteUrl}/#person` },
    },
    {
      '@type': 'Service',
      '@id': `${siteConfig.siteUrl}/#service`,
      name: 'Internal AI Build, Hardening & Advisory',
      provider: { '@id': `${siteConfig.siteUrl}/#person` },
      serviceType: ['Build', 'Hardening', 'Advisory'],
      description: 'Project-based build, hardening, and advisory work for internal AI systems in enterprise and mid-market workflows.',
      url: `${siteConfig.siteUrl}/services/`,
      areaServed: 'Worldwide',
    },
  ]}
>
  <SiteHeader />

  <main id="main">
    <Hero
      title={siteConfig.heroTitle}
      description={siteConfig.heroDescription}
      primaryCta={siteConfig.heroPrimaryCta}
      secondaryCta={siteConfig.heroSecondaryCta}
      portrait={{ src: '/stefan-manja-context.webp', alt: 'Stefan Manja' }}
    />

    <ProofStrip items={proofPoints} />

    <section class="section-space pt-8 sm:pt-10">
      <div class="shell">
        <div class="page-lead">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">01 / selected work</span>
            <p class="eyebrow">Selected work</p>
          </div>
          <h2 class="page-title">Concrete delivery choices, system shape, and outcomes that mattered.</h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {caseStudies.map((entry) => <CaseStudyCard entry={entry} />)}
        </div>

        <div class="mt-6">
          <a class="ink-link inline-flex min-h-[44px] items-center py-2 text-sm font-semibold transition" href="/work">
            See all work →
          </a>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-6 px-6 py-8 sm:px-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">02 / context</span>
              <p class="eyebrow">About Stefan</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Enterprise AI delivery shaped by finance, industrial, and earlier decision-support environments.
            </h2>
            <p class="text-base leading-8 muted-copy">
              I currently work in an enterprise and industrial environment and previously spent four years at Delta Holding,
              progressing from AI Specialist to AI Innovation Lead while helping move internal AI from early opportunity framing
              to first scaled rollout across multiple business units. Before that, I spent years building decision-support systems
              in operational settings where field constraints, adoption, and workflow fit mattered more than model novelty.
              That continuity still shapes how I approach enterprise AI work now.
            </p>
            <div class="space-y-4 pt-2">
              <div class="technical-rule">
                <p class="metric-label">Availability</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Available for selective project work.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Delivery environments</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Delta Holding work across credit workflows, internal assistants, and AI delivery programs, plus earlier decision-support systems in operational environments.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Working principle</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Workflow fit, reviewability, and handoff quality matter as much as model output. A system has to earn continued use; it does not get it by default.</p>
              </div>
            </div>
          </div>

          <div class="lg:pt-16">
            <div class="panel panel-light overflow-hidden p-0">
              <div class="border-b border-[color:var(--rule)] bg-[rgba(255,252,247,0.72)] px-6 py-4">
                <div class="accent-bar"></div>
                <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                  <p class="eyebrow">Operating model</p>
                  <span class="rounded-full border border-[color:var(--rule)] bg-white/80 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-[color:var(--muted)]">
                    Scope → Build → Harden → Handoff
                  </span>
                </div>
                <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
                  A compact operating artifact: define the workflow, ship the first version, tighten the edges, and leave the team something it can run.
                </p>
              </div>

              <div class="px-6 py-5">
                <div class="grid gap-3 sm:grid-cols-2">
                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">01 / scope</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Align on workflow and constraints</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Define the users, ownership, timing, and what useful needs to mean in practice.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">02 / build</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Ship a first version</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Use decisions that support real use, feedback, and reliable deployment.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">03 / harden</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Tighten the failure modes</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Make evaluation, reviewability, and operator visibility part of the system.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-[rgba(255,250,243,0.92)] p-4">
                    <p class="metric-label">04 / handoff</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Leave something operable</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      The team should be able to run, review, and extend the work without mythology.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">03 / services</span>
              <p class="eyebrow">How I help</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Project-based build first, with hardening and advisory work where they improve delivery.
            </h2>
            <p class="text-base leading-8 muted-copy">
              Build is the main entry point. The service page goes deeper on project shapes, engagement flow, and where
              hardening or advisory work help delivery.
            </p>
          </div>
          <a class="ink-link text-sm font-semibold transition" href="/services">
            See project shapes →
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-8 px-6 py-10 sm:px-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">04 / public proof</span>
              <p class="eyebrow">Working style</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              A public proof point for the working style behind the delivery.
            </h2>
            <p class="text-base leading-8 muted-copy">
              The Agentic Development Playbook is a public artifact showing how I keep AI implementation scoped,
              reviewable, and evaluation-gated once work becomes repo-level and real delivery starts.
            </p>
          </div>

          <div class="panel panel-dark p-6">
            <div class="accent-bar"></div>
            <p class="text-sm leading-7 text-stone-300">
              Public artifact, not a private claims page: scoped tasks, verification before commit, repo files as the source
              of truth, and a light PoC/evaluation path when early work still needs decision-grade evidence. That discipline
              is what makes delivered work auditable, operable, and easier for your team to extend after the engagement ends.
            </p>
            <a
              class="mt-6 inline-flex text-sm font-semibold text-stone-100 transition hover:text-[color:var(--accent-strong)]"
              href={siteConfig.playbookUrl}
              target="_blank"
              rel="noreferrer"
            >
              View the Playbook →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break max-w-3xl space-y-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">05 / fit</span>
            <p class="eyebrow">Fit guidance</p>
          </div>
          <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            The strongest work starts with a clear operating problem, real users, and a reason the system needs to hold up once it's live.
          </h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Good fit</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              {fitGuidance.goodFit.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Usually too early or not the right shape</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              {fitGuidance.notFit.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <CTASection
      title="If the workflow is concrete enough to describe, I can usually tell quickly whether a build or advisory conversation makes sense."
      description="I take on project-based build, hardening, and advisory work for internal AI systems. A short description of the workflow, the current stage, and the key constraints is enough to tell whether the engagement makes sense."
      primary={siteConfig.heroPrimaryCta}
      secondary={{ href: '/services', label: 'See project shapes' }}
    />
  </main>

  <SiteFooter />
</BaseLayout>
