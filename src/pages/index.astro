---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Hero from '../components/Hero.astro';
import ProofStrip from '../components/ProofStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import CTASection from '../components/CTASection.astro';
import { fitGuidance, proofPoints, services, siteConfig } from '../config/site';

const caseStudies = (await getCollection('case-studies'))
  .sort((left, right) => left.data.order - right.data.order)
  .slice(0, 2);
---

<BaseLayout
  pathname="/"
  title="Internal AI Systems for Enterprise Workflows"
  description={siteConfig.defaultDescription}
  pageSchema={[
    {
      '@type': 'WebPage',
      '@id': `${siteConfig.siteUrl}/#webpage`,
      url: `${siteConfig.siteUrl}/`,
      name: 'Internal AI Systems for Enterprise Workflows | Stefan Manja',
      description: siteConfig.defaultDescription,
      author: { '@id': `${siteConfig.siteUrl}/#person` },
    },
    {
      '@type': 'Service',
      '@id': `${siteConfig.siteUrl}/#service`,
      name: 'Internal AI Build, Hardening & Advisory',
      provider: { '@id': `${siteConfig.siteUrl}/#person` },
      serviceType: ['Build', 'Hardening', 'Advisory'],
      description: 'Project-based build, hardening, and advisory work for internal AI systems in enterprise and mid-market workflows.',
      url: `${siteConfig.siteUrl}/services/`,
      areaServed: 'Worldwide',
    },
  ]}
>
  <SiteHeader />

  <main>
    <Hero
      title={siteConfig.heroTitle}
      description={siteConfig.heroDescription}
      primaryCta={siteConfig.heroPrimaryCta}
      secondaryCta={siteConfig.heroSecondaryCta}
    />

    <ProofStrip items={proofPoints} />

    <section class="section-space pt-8 sm:pt-10">
      <div class="shell">
        <div class="page-lead">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">01 / selected work</span>
            <p class="eyebrow">Selected work</p>
          </div>
          <h2 class="page-title">
            Selected proof first: concrete delivery choices, system shape, and outcomes that mattered in real environments.
          </h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {caseStudies.map((entry) => <CaseStudyCard entry={entry} />)}
        </div>

        <div class="mt-6">
          <a class="ink-link inline-flex min-h-[44px] items-center py-2 text-sm font-semibold transition" href="/work">
            See all work →
          </a>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-6 px-6 py-8 sm:px-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">02 / context</span>
              <p class="eyebrow">About Stefan</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Enterprise AI delivery shaped by finance, industrial, and earlier decision-support environments.
            </h2>
            <p class="text-base leading-8 muted-copy">
              I currently work in an enterprise and industrial environment and previously spent four years at Delta Holding,
              progressing from AI Specialist to AI Innovation Lead while helping move internal AI from early opportunity framing
              to first scaled rollout across multiple business units. Before that, I spent years building decision-support systems
              in operational settings where field constraints, adoption, and workflow fit mattered more than model novelty.
              That continuity still shapes how I approach enterprise AI work now.
            </p>
            <div class="space-y-4 pt-2">
              <div class="technical-rule">
                <p class="metric-label">Current role</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Applied AI in an enterprise and industrial environment, alongside selective project work.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Delivery environments</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Delta Holding work across credit workflows, internal assistants, and AI delivery programs, plus earlier decision-support systems in operational environments.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Why teams bring me in</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">I tend to be most useful where workflow constraints, reviewability, and handoff quality matter as much as model output.</p>
              </div>
            </div>
          </div>

          <div class="lg:pt-32">
            <div class="mx-auto w-full max-w-[16rem] overflow-hidden rounded-[1.2rem] border border-[color:var(--rule)] bg-white/70 sm:max-w-[17rem] lg:max-w-[18rem]">
              <img
                src="/stefan-manja-context.webp"
                alt="Stefan Manja"
                width="720"
                height="900"
                loading="lazy"
                class="block h-auto w-full"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">03 / services</span>
              <p class="eyebrow">How I help</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Project-based build first, with hardening and advisory work where they improve delivery.
            </h2>
            <p class="text-base leading-8 muted-copy">
              The main fit is an internal workflow with real users, a concrete owner, and a reason the system needs to keep working once it ships. The service page goes deeper on project shapes and engagement flow.
            </p>
          </div>
          <a class="ink-link text-sm font-semibold transition" href="/services">
            See project shapes →
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-8 px-6 py-10 sm:px-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">04 / public proof</span>
              <p class="eyebrow">Working style</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              A public proof point for the working style behind the delivery.
            </h2>
            <p class="text-base leading-8 muted-copy">
              The Agentic Development Playbook is not the main offer on this site. It is public evidence of how I keep AI
              implementation scoped, reviewable, and evaluation-gated once work becomes repo-level and real delivery starts.
            </p>
          </div>

          <div class="panel panel-dark p-6">
            <div class="accent-bar"></div>
            <p class="text-sm leading-7 text-stone-300">
              Public artifact, not a private claims page: scoped tasks, verification before commit, repo files as the source
              of truth, and a light PoC/evaluation path when early work still needs decision-grade evidence.
            </p>
            <a
              class="mt-6 inline-flex text-sm font-semibold text-stone-100 transition hover:text-[color:var(--accent-strong)]"
              href={siteConfig.playbookUrl}
              target="_blank"
              rel="noreferrer"
            >
              View the Playbook →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break max-w-3xl space-y-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">05 / fit</span>
            <p class="eyebrow">Fit guidance</p>
          </div>
          <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            The strongest work starts with a concrete workflow, real users, and a reason the system needs to perform reliably once it's live.
          </h2>
          <p class="text-base leading-8 muted-copy">
            This is a better fit for scoped build, hardening, or advisory work than for open-ended AI exploration without an
            owner, workflow, or adoption path.
          </p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Good fit</p>
            <ul class="mt-6 space-y-3 text-sm leading-7 text-[color:var(--ink-soft)]">
              {fitGuidance.goodFit.map((item) => <li>• {item}</li>)}
            </ul>
          </article>

          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Not a fit</p>
            <ul class="mt-6 space-y-3 text-sm leading-7 text-[color:var(--ink-soft)]">
              {fitGuidance.notFit.map((item) => <li>• {item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <CTASection
      title="If the workflow is concrete enough to describe, I can usually tell quickly whether a build or advisory conversation makes sense."
      description="I take on project-based build, hardening, and advisory work for internal AI systems. The strongest first conversations are about a concrete workflow, the current stage, and the constraints that will decide whether the system actually gets adopted."
      primary={siteConfig.heroPrimaryCta}
      secondary={{ href: '/services', label: 'See project shapes' }}
    />
  </main>

  <SiteFooter />
</BaseLayout>
