---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import { services, siteConfig } from '../config/site';
---

<BaseLayout
  pathname="/services/"
  title="Internal AI Build, Hardening & Advisory"
  description="Project shapes, service modes, and delivery paths for internal AI systems that need disciplined evaluation and real-world usability."
  pageSchema={[
    {
      '@type': 'Service',
      '@id': `${siteConfig.siteUrl}/#service`,
      name: 'Internal AI Build, Hardening & Advisory',
      provider: { '@id': `${siteConfig.siteUrl}/#person` },
      serviceType: ['Build', 'Hardening', 'Advisory'],
      description: 'Project-based build, hardening, and advisory work for internal AI systems in enterprise and mid-market workflows.',
      url: `${siteConfig.siteUrl}/services/`,
    },
  ]}
>
  <SiteHeader />

  <main id="main">
    <section class="section-space">
      <div class="shell">
        <div class="page-lead">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">01 / project shapes</span>
            <p class="eyebrow">Services</p>
          </div>
          <h1 class="page-title">
            Project shapes, delivery modes, and the engagement patterns that create real leverage.
          </h1>
          <p class="text-base leading-8 muted-copy">
            This page is for teams that already have a real workflow, known users, and a defined owner. The main fit is
            project-based build work, with hardening and scoped advisory support where they improve delivery.
          </p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Best starting points</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              <li>A workflow owner can describe the current pain clearly.</li>
              <li>The users are known, and there is already business pull for the work.</li>
              <li>The question is how to build or harden the system responsibly, not whether AI is fashionable.</li>
            </ul>
          </article>

          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">How I usually engage</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              <li>Project-based builds for new internal systems.</li>
              <li>Scoped hardening work for prototypes or pilots already in motion.</li>
              <li>Advisory support tied to an actual delivery decision, not broad transformation work without something concrete to ship or improve.</li>
            </ul>
          </article>
        </div>

        <div class="mt-4 panel panel-light p-6">
          <div class="accent-bar"></div>
          <p class="eyebrow">What this usually looks like</p>
          <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
            <li>Analysts pulling context from multiple systems before a repeatable decision, where the current process is slow, inconsistent, or hard to review.</li>
            <li>An internal assistant that is useful in a demo, but still needs scoped access, feedback loops, and operator visibility before broader use.</li>
            <li>A prototype with clear business pull that still lacks evaluation, failure handling, or handoff discipline once it has to survive real use.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break max-w-3xl space-y-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">02 / service modes</span>
            <p class="eyebrow">How I engage</p>
          </div>
          <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            Build stays primary. Hardening and advisory work exist to support delivery quality.
          </h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light px-6 py-8 sm:px-10">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">03 / delivery path</span>
            <p class="eyebrow">Typical engagement shape</p>
          </div>
          <ol class="mt-6 grid gap-4 text-sm leading-7 text-[color:var(--ink-soft)] sm:grid-cols-2">
            <li class="rounded-2xl border border-[color:var(--rule)] bg-white/70 p-5">
              <span class="metric-label text-[color:var(--accent)]" aria-hidden="true">Step 01</span>
              <span class="mt-3 block font-semibold text-[color:var(--ink)]">Scope</span>
              <span class="mt-2 block">Align on workflow, users, constraints, and what “useful” means in practice.</span>
            </li>
            <li class="rounded-2xl border border-[color:var(--rule)] bg-white/70 p-5">
              <span class="metric-label text-[color:var(--accent)]" aria-hidden="true">Step 02</span>
              <span class="mt-3 block font-semibold text-[color:var(--ink)]">Build</span>
              <span class="mt-2 block">Implement the first version with decisions that support real use, not demo optics.</span>
            </li>
            <li class="rounded-2xl border border-[color:var(--rule)] bg-white/70 p-5">
              <span class="metric-label text-[color:var(--accent)]" aria-hidden="true">Step 03</span>
              <span class="mt-3 block font-semibold text-[color:var(--ink)]">Harden</span>
              <span class="mt-2 block">Tighten evaluation, guard against failure modes, and make prototype-to-production behavior legible.</span>
            </li>
            <li class="rounded-2xl border border-[color:var(--rule)] bg-white/70 p-5">
              <span class="metric-label text-[color:var(--accent)]" aria-hidden="true">Step 04</span>
              <span class="mt-3 block font-semibold text-[color:var(--ink)]">Handoff</span>
              <span class="mt-2 block">Leave behind something your team can operate, review, and extend without mythology.</span>
            </li>
          </ol>
          <p class="mt-8 border-t border-[color:var(--rule)] pt-6 text-sm leading-7 text-[color:var(--muted)]">
            Most engagements are bounded around a concrete build or hardening goal rather than open-ended transformation support.
            Typical work runs in weeks rather than as an open-ended retainer. The first step is usually a short scope
            conversation - enough to align on what the work involves, what a useful outcome looks like, and whether the
            engagement shape makes sense. Most work is scoped tightly enough to stay reviewable and useful without turning
            into open-ended support.
          </p>
          <div class="mt-8 border-t border-[color:var(--rule)] pt-6">
            <div class="rounded-2xl border border-[color:var(--rule)] bg-[rgba(255,252,247,0.72)] p-5">
              <p class="eyebrow">What you get</p>
              <div class="mt-4 grid gap-4 sm:grid-cols-3">
                <div class="rounded-2xl border border-[color:var(--rule)] bg-white/80 p-4">
                  <p class="metric-label text-[color:var(--accent)]">01 / plan</p>
                  <p class="mt-2 font-semibold text-[color:var(--ink)]">Scoped build plan</p>
                  <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                    Workflow boundary, ownership model, and delivery path in one place.
                  </p>
                </div>
                <div class="rounded-2xl border border-[color:var(--rule)] bg-white/80 p-4">
                  <p class="metric-label text-[color:var(--accent)]">02 / ship</p>
                  <p class="mt-2 font-semibold text-[color:var(--ink)]">Delivered implementation</p>
                  <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                    Build-first changes, or a concrete next-step package when the engagement is advisory-first.
                  </p>
                </div>
                <div class="rounded-2xl border border-[color:var(--rule)] bg-white/80 p-4">
                  <p class="metric-label text-[color:var(--accent)]">03 / handoff</p>
                  <p class="mt-2 font-semibold text-[color:var(--ink)]">Evaluation + handoff pack</p>
                  <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                    Notes your team can operate from without having the work explained twice.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTASection
      title="If the workflow is real enough to scope, I can usually tell quickly whether the project shape makes sense."
      description="A short outline of the workflow, the current stage, and whether this is build, hardening, or scoped advisory work is usually enough for a first pass."
      primary={siteConfig.heroPrimaryCta}
      secondary={{ href: '/work', label: 'View case studies' }}
    />
  </main>

  <SiteFooter />
</BaseLayout>
