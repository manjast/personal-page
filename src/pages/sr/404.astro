---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const locale = 'sr';
const alternates = {
  en: '/',
  sr: '/sr/',
};
---

<BaseLayout locale={locale} pathname="/sr/404" title="Страница није пронађена" noindex={true}>
  <SiteHeader locale={locale} alternates={alternates} />

  <main id="main" class="section-space">
    <div class="shell">
      <div class="panel panel-light max-w-3xl p-8 sm:p-10">
        <div class="accent-bar"></div>
        <p class="eyebrow">404</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-[color:var(--ink)]">Та страница не постоји.</h1>
        <p class="mt-4 text-base leading-8 muted-copy">
          Најбољи пут назад је обично почетна страна, страница пројеката или контакт страница.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href="/sr/">На почетну</a>
          <a class="button-secondary" href="/sr/work/">Погледајте пројекте</a>
        </div>
      </div>
    </div>
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
