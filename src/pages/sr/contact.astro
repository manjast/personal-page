---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getSiteContent } from '../../config/site';

const locale = 'sr';
const content = getSiteContent(locale);
const { contactExpectations, fitGuidance, siteConfig } = content;
const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID;
const formAction = formId ? `https://formspree.io/f/${formId}` : undefined;
const formSuccessPath = '/sr/contact/sent/';
---

<BaseLayout
  locale={locale}
  pathname="/sr/contact/"
  title="Процена интерног AI процеса"
  description="Пошаљите интерни AI процес на фокусирану процену код Стефана Мање."
  pageSchema={[
    {
      '@type': 'ContactPage',
      '@id': `${siteConfig.siteUrl}/sr/contact/#webpage`,
      url: `${siteConfig.siteUrl}/sr/contact/`,
      name: 'Процена интерног AI процеса | Стефан Мања',
      author: { '@id': `${siteConfig.siteUrl}/#person` },
      inLanguage: 'sr-Cyrl',
    },
  ]}
>
  <SiteHeader locale={locale} />

  <main id="main">
    <section class="section-space">
      <div class="shell">
        <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
          <div class="space-y-6">
            <div class="page-lead">
              <div class="flex flex-wrap items-center gap-3">
                <span class="section-marker">01 / контакт</span>
                  <p class="eyebrow">Процена процеса</p>
              </div>
              <h1 class="page-title">
                 Почните од процеса.
              </h1>
                <p class="text-base leading-8 muted-copy">
                  Радим на малом броју пројеката у којима су оперативни проблем, власник и границе довољно конкретни
                  да рад има смисла. Не морате унапред имати обликовано решење; корисна почетна тачка је сам процес
                  и шта треба да постане лакше, брже, безбедније или проверљивије. Разговори се воде поверљиво,
                  а интерни контекст се третира пажљиво.
                </p>
            </div>

            <div class="panel panel-light p-6">
              <div class="accent-bar"></div>
              <p class="text-sm font-semibold text-[color:var(--ink)]">Директан имејл</p>
              <a
                id="contact-email-link"
                class="mt-3 inline-flex h-11 items-center text-base font-semibold text-[color:var(--ink)] transition hover:text-[color:var(--accent)]"
                href={`mailto:${siteConfig.email}`}
              >
                {siteConfig.email}
              </a>
              <p class="mt-4 text-sm leading-7 muted-copy">{contactExpectations.responseTime}</p>
              <p class="mt-2 text-sm leading-7 muted-copy">{contactExpectations.fitNote}</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-1">
              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Добар први имејл</p>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                  <li>Процес и корисници могу лако да се опишу.</li>
                  <li>Можете да кажете да ли је реч о новој изградњи, постојећем прототипу или одлуци коју треба проверити.</li>
                  <li>Већ постоје власник, тренутна фаза и ограничење које ће у пракси бити важно.</li>
                </ul>
              </article>

              <article class="panel panel-light p-6">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Обично прерано или није прави тип пројекта</p>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                  {fitGuidance.notFit.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            </div>
          </div>

          {
            formAction ? (
              <div class="panel panel-light p-6 sm:p-8">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-[color:var(--ink)]">Процена процеса</p>
                <p class="mt-3 text-sm leading-7 muted-copy">Довољно контекста за прву процену.</p>

                <form id="contact-form" class="mt-8 space-y-6" method="POST" action={formAction}>
                  <input type="hidden" name="_subject" value="Процена интерног AI процеса — stefanmanja.com" />
                  <input id="contact-form-next" type="hidden" name="_next" value={formSuccessPath} />
                  <div class="absolute -left-[9999px] h-0 w-0 overflow-hidden opacity-0" aria-hidden="true">
                    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
                  </div>
                  <div class="grid gap-6 sm:grid-cols-2">
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Име
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="name" autocomplete="name" required />
                    </label>

                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                      Пословни имејл
                      <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="email" name="email" autocomplete="email" required />
                    </label>
                  </div>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]">
                    Компанија или тим
                    <input class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" type="text" name="company" autocomplete="organization" />
                  </label>

                  <div>
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="use-case">
                      Шта желите да изградите или побољшате?
                    </label>
                    <textarea
                      id="use-case"
                      class="mt-2.5 min-h-[7.5rem] w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]"
                      name="use_case"
                      aria-describedby="use-case-hint"
                      required
                    ></textarea>
                    <p id="use-case-hint" class="mt-2 text-xs leading-5 muted-copy">Једна или две реченице су довољне.</p>
                  </div>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="primary-concern">
                    Главна брига
                    <select id="primary-concern" class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="primary_concern" required>
                      <option value="">Изаберите једно</option>
                      <option value="worth-building">Одлучујемо да ли ово вреди градити</option>
                      <option value="prototype-hardening">Имамо прототип, али није спреман за стварну употребу</option>
                      <option value="assistant-readiness">Интерни асистент / RAG систем треба проверу спремности</option>
                      <option value="decision-support">Аналитичком процесу треба подршка у одлучивању</option>
                      <option value="second-opinion">Треба нам друго мишљење о добављачу или архитектури</option>
                      <option value="other">Друго</option>
                    </select>
                  </label>

                  <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="current-stage">
                    Тренутна фаза
                    <select id="current-stage" class="mt-2.5 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]" name="current_stage" required>
                      <option value="">Изаберите једно</option>
                      <option value="exploring">Процес је дефинисан, приступ се још бира</option>
                      <option value="prototype">Прототип постоји</option>
                      <option value="hardening">Потребна је припрема за продукцију</option>
                      <option value="replace-rescue">Мењамо или спасавамо постојећи процес</option>
                    </select>
                  </label>

                  <fieldset class="space-y-3">
                    <legend class="text-sm font-medium text-[color:var(--ink-soft)]">Позната ограничења</legend>
                    <div class="grid gap-3 sm:grid-cols-2">
                      {
                        [
                          'Ограничења података или приступа',
                          'Неопходна је људска провера',
                          'Брига о трошковима или коришћењу',
                          'Захтеви усклађености или интерна правила',
                          'Постојећи прототип или добављач',
                          'Притисак рокова',
                          'Потребна је интерна предаја',
                        ].map((constraint) => (
                          <label class="flex min-h-[44px] items-start gap-3 rounded-2xl border border-[color:var(--rule)] bg-white/65 px-4 py-3 text-sm leading-6 text-[color:var(--ink-soft)]">
                            <input
                              class="mt-1 h-4 w-4 rounded border-[color:var(--rule)] text-[color:var(--accent)] focus:ring-[color:var(--accent)]"
                              type="checkbox"
                              name="constraints"
                              value={constraint}
                            />
                            <span>{constraint}</span>
                          </label>
                        ))
                      }
                    </div>
                  </fieldset>

                  <div>
                    <label class="block text-sm font-medium text-[color:var(--ink-soft)]" for="context">
                      Релевантан контекст
                    </label>
                    <textarea
                      id="context"
                      class="mt-2.5 min-h-40 w-full rounded-2xl border border-[color:var(--rule)] bg-white/85 px-4 py-3 text-sm text-[color:var(--ink)] outline-none transition focus:border-[color:var(--accent)]"
                      name="context"
                      aria-describedby="context-hint"
                      required
                    ></textarea>
                    <p id="context-hint" class="mt-2 text-xs leading-5 muted-copy">
                      Тренутни алати, величина тима, притисак рокова или захтеви поверења - шта год је већ јасно.
                    </p>
                  </div>

                  <button class="button-primary" type="submit">
                    Пошаљите опис процеса
                  </button>
                  <p class="text-sm leading-7 muted-copy">
                    Поруке се шаљу преко Formspree-ја и користе се само за одговор на вашу поруку.
                  </p>
                </form>
                <div class="mt-8 border-t border-[color:var(--rule)] pt-6">
                  <p class="text-sm font-semibold text-[color:var(--ink)]">Шта се дешава следеће</p>
                  <ul class="mt-4 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
                    <li>Прегледам процес, тренутну фазу и ограничења.</li>
                    <li>Ако делује као пројекат где могу да допринесем, одговарам у року од 3 радна дана.</li>
                    <li>Ако је корисно, указујем на вероватан следећи корак: изградња, стабилизација, поједностављење, заустављање или краћи саветодавни разговор.</li>
                    <li>Ако није прави тип пројекта, обично то кажем директно.</li>
                  </ul>
                </div>
              </div>
            ) : (
              <div class="panel panel-dark p-6 sm:p-8 lg:sticky lg:top-28">
                <div class="accent-bar"></div>
                <p class="text-sm font-semibold text-stone-50">Шта укључити у опис процеса</p>
                <p class="mt-3 text-sm leading-7 text-stone-300">{contactExpectations.emailPrompt}</p>
                <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-stone-300 marker:text-stone-500">
                  <li>Процес и ко га данас користи</li>
                  <li>Главна брига: изводљивост, стабилизација, спремност асистента, подршка одлукама или друго мишљење</li>
                  <li>Шта би морало да буде поуздано да би систем био користан</li>
                  <li>Рокови, хостинг, идентитет или ограничења усклађености која већ нешто значе</li>
                </ul>
                <a class="button-primary-invert mt-8" href={`mailto:${siteConfig.email}?subject=Процена интерног AI процеса`}>
                  Пошаљите опис имејлом
                </a>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>

  <SiteFooter locale={locale} />
  <script is:inline>
    const contactFormNext = document.getElementById('contact-form-next');

    if (contactFormNext instanceof HTMLInputElement) {
      contactFormNext.value = `${window.location.origin}${contactFormNext.value}`;
    }

    document.getElementById('contact-email-link')?.addEventListener('click', function () {
      if (window.goatcounter && window.goatcounter.count) {
        window.goatcounter.count({ path: 'contact-email-click', title: 'Contact: Email Click', event: true });
      }
    });

    document.getElementById('contact-form')?.addEventListener('submit', function () {
      if (window.goatcounter && window.goatcounter.count) {
        window.goatcounter.count({ path: 'contact-form-submit', title: 'Contact: Form Submit', event: true });
      }
    });
  </script>
</BaseLayout>
