---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getSiteContent } from '../../config/site';
import { localizedHref } from '../../i18n/routing';

const locale = 'sr';
const content = getSiteContent(locale);
const { fitGuidance, proofPoints, services, siteConfig } = content;
const caseStudies = (await getCollection('case-studies'))
  .filter((entry) => entry.data.locale === locale)
  .sort((left, right) => left.data.order - right.data.order)
  .slice(0, 2);
const primaryCta = { ...siteConfig.heroPrimaryCta, href: localizedHref(locale, siteConfig.heroPrimaryCta.href) };
const secondaryCta = { ...siteConfig.heroSecondaryCta, href: localizedHref(locale, siteConfig.heroSecondaryCta.href) };
---

<BaseLayout
  locale={locale}
  pathname="/sr/"
  title="Интерни системи вештачке интелигенције за пословне токове"
  description={siteConfig.defaultDescription}
  pageSchema={[
    {
      '@type': 'WebPage',
      '@id': `${siteConfig.siteUrl}/sr/#webpage`,
      url: `${siteConfig.siteUrl}/sr/`,
      name: 'Интерни системи вештачке интелигенције за пословне токове | Stefan Manja',
      description: siteConfig.defaultDescription,
      author: { '@id': `${siteConfig.siteUrl}/#person` },
      inLanguage: 'sr-Cyrl',
    },
    {
      '@type': 'Service',
      '@id': `${siteConfig.siteUrl}/sr/#service`,
      name: 'Изградња, ојачавање и саветовање за интерне системе вештачке интелигенције',
      provider: { '@id': `${siteConfig.siteUrl}/#person` },
      serviceType: ['Изградња', 'Ојачавање', 'Саветовање', 'Преглед изводљивости радног тока', 'Ојачавање пилота', 'Изградња подршке одлукама'],
      description: 'Пројектна изградња, ојачавање и саветовање за интерне системе вештачке интелигенције у пословним токовима предузећа и средње великих организација.',
      url: `${siteConfig.siteUrl}/sr/services/`,
      areaServed: 'Међународно',
      inLanguage: 'sr-Cyrl',
    },
  ]}
>
  <SiteHeader locale={locale} />

  <main id="main">
    <Hero
      eyebrow={content.ui.heroEyebrow}
      sectionMarker={content.ui.heroMarker}
      title={siteConfig.heroTitle}
      description={siteConfig.heroDescription}
      primaryCta={primaryCta}
      secondaryCta={secondaryCta}
      locationBadge={siteConfig.locationBadge}
      portrait={{ src: '/stefan-manja-context.webp', alt: 'Стефан Мања' }}
      operatingBrief={content.ui.operatingBrief}
    />

    <ProofStrip items={proofPoints} />

    <section class="section-space pt-8 sm:pt-10">
      <div class="shell">
        <div class="page-lead">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">01 / изабрани рад</span>
            <p class="eyebrow">Изабрани рад</p>
          </div>
          <h2 class="page-title">Конкретне одлуке испоруке, облик система и исходи који су били важни.</h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {caseStudies.map((entry) => <CaseStudyCard entry={entry} locale={locale} />)}
        </div>

        <div class="mt-6">
          <a class="ink-link inline-flex min-h-[44px] items-center py-2 text-sm font-semibold transition" href="/sr/work/">
            Погледајте сав рад →
          </a>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-6 px-6 py-8 sm:px-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">02 / контекст</span>
              <p class="eyebrow">О Стефану</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Испорука вештачке интелигенције у предузећима, обликована искуством из финансија, индустријских окружења и ранијих система за подршку одлукама.
            </h2>
            <p class="text-base leading-8 muted-copy">
              Тренутно радим у корпоративном и индустријском окружењу, а раније сам четири године радио у Delta Holdingu,
              напредујући од AI Specialist до AI Innovation Lead, док сам помагао да интерни рад са вештачком интелигенцијом
              пређе од раног уоквиравања прилика до првог увођења у више пословних целина.
            </p>
            <p class="text-base leading-8 muted-copy">
              Пре садашњег таласа вештачке интелигенције радио сам на системима за подршку одлукама у оперативној пољопривреди
              и BI окружењима: предиктивним токовима заштите биља и наводњавања, IoT подацима са терена, ETL-у, KPI извештавању
              и тимовима који су усвајали алате само ако су помагали стварном оперативном раду. Зато облик система, пут усвајања
              и власништво третирам као кључна пројектна ограничења, не као накнадно сређивање имплементације.
            </p>
            <div class="space-y-4 pt-2">
              <div class="technical-rule">
                <p class="metric-label">Доступност</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Доступан за селективан пројектни рад.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Тренутни рад</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Примењена вештачка интелигенција за интерне индустријске радне токове и инжењерске контексте са великим ослањањем на податке. Јавни опис је намерно ограничен на облик радног тока и проблема.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Окружења испоруке</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Рад у Delta Holdingu преко кредитних токова, интерних асистената и програма испоруке вештачке интелигенције, уз раније системе подршке одлукама у оперативним окружењима.</p>
              </div>
              <div class="technical-rule">
                <p class="metric-label">Радно начело</p>
                <p class="mt-2 text-sm leading-7 text-[color:var(--ink-soft)]">Уклапање у радни ток, проверљивост и квалитет предаје важни су колико и излаз модела. Систем мора да заслужи трајну употребу; не добија је подразумевано.</p>
              </div>
            </div>
          </div>

          <div class="lg:pt-16">
            <div class="panel panel-light overflow-hidden p-0">
              <div class="border-b border-[color:var(--rule)] bg-[rgba(255,252,247,0.72)] px-6 py-4">
                <div class="accent-bar"></div>
                <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                  <p class="eyebrow">Оперативни модел</p>
                  <span class="rounded-full border border-[color:var(--rule)] bg-white/80 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-[color:var(--muted)]">
                    Обим → Изградња → Ојачавање → Предаја
                  </span>
                </div>
                <p class="mt-3 text-sm leading-6 text-[color:var(--muted)]">
                  Компактан оперативни артефакт: дефинисати радни ток, испоручити прву верзију, покрити рубне случајеве и оставити тиму нешто што може да води.
                </p>
              </div>

              <div class="px-6 py-5">
                <div class="grid gap-3 sm:grid-cols-2">
                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">01 / обим</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Ускладити радни ток и ограничења</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Дефинисати кориснике, власништво, време и шта „корисно” мора да значи у пракси.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">02 / изградња</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Испоручити прву верзију</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Користити одлуке које подржавају стварну употребу, повратне сигнале и поуздано увођење.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-white/82 p-4">
                    <p class="metric-label">03 / ојачавање</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Затегнути начине отказа</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Учинити проверу, проверљивост и операторску видљивост делом система.
                    </p>
                  </div>

                  <div class="rounded-2xl border border-[color:var(--rule)] bg-[rgba(255,250,243,0.92)] p-4">
                    <p class="metric-label">04 / предаја</p>
                    <p class="mt-2 font-semibold text-[color:var(--ink)]">Оставити нешто оперативно</p>
                    <p class="mt-2 text-sm leading-6 text-[color:var(--ink-soft)]">
                      Тим треба да може да води, прегледа и проширује рад без митологије.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">03 / услуге</span>
              <p class="eyebrow">Како помажем</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Пројектна изградња је прва, уз ојачавање и саветовање када они побољшавају поузданост, проверљивост и предају.
            </h2>
            <p class="text-base leading-8 muted-copy">
              Изградња је главна улазна тачка. Страница услуга детаљније описује почетне тачке радних токова,
              облик ангажмана и где ојачавање или саветовање помажу да систем издржи стварне оперативне услове.
            </p>
            <p class="text-base leading-8 muted-copy">
              Тимови се обично јављају када треба да одлуче да ли је радни ток са вештачком интелигенцијом вредан изградње,
              да ојачају прототип који ради само у демонстрационим условима, да припреме интерног асистента за стварну употребу
              или да изграде подршку одлукама око аналитичког радног тока.
            </p>
          </div>
          <a class="ink-link inline-flex min-h-[44px] items-center self-start py-2 text-sm font-semibold transition" href="/sr/services/">
            Погледајте почетне тачке радних токова →
          </a>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {services.map((service) => <ServiceCard service={service} locale={locale} />)}
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break panel panel-light grid gap-8 px-6 py-10 sm:px-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="section-marker">04 / јавни доказ</span>
              <p class="eyebrow">Начин рада</p>
            </div>
            <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
              Јавни доказ за начин рада који стоји иза испоруке.
            </h2>
            <p class="text-base leading-8 muted-copy">
              Agentic Development Playbook је јавни артефакт који показује како држим имплементацију вештачке интелигенције
              ограниченом, проверљивом и везаном за евалуацију када рад пређе на ниво репозиторијума и стварна испорука почне.
            </p>
          </div>

          <div class="panel panel-dark p-6">
            <div class="accent-bar"></div>
            <p class="text-sm leading-7 text-stone-300">
              Јавни артефакт, не приватна страница тврдњи: ограничени задаци, провера пре уписа измена, датотеке репозиторијума као извор истине
              и лаган пут доказа концепта или евалуације када рани рад још треба доказ за одлуку. Та дисциплина чини испоручени рад проверљивим,
              оперативним и лакшим за тим да га прошири после ангажмана.
            </p>
            <a
              class="mt-6 inline-flex min-h-[44px] items-center py-2 text-sm font-semibold text-stone-100 transition hover:text-[color:var(--accent-strong)]"
              href={siteConfig.playbookUrl}
              target="_blank"
              rel="noreferrer"
            >
              Погледајте Playbook →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space pt-0">
      <div class="shell">
        <div class="section-break max-w-3xl space-y-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">05 / уклапање</span>
            <p class="eyebrow">Смернице уклапања</p>
          </div>
          <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            Најјачи рад почиње јасним оперативним проблемом, стварним корисницима и разлогом да систем мора да издржи када је уживо.
          </h2>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Добро уклапање</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              {fitGuidance.goodFit.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="panel panel-light p-6">
            <div class="accent-bar"></div>
            <p class="eyebrow">Обично прерано или погрешан облик</p>
            <ul class="mt-6 list-disc space-y-3 pl-5 text-sm leading-7 text-[color:var(--ink-soft)] marker:text-[color:var(--muted-soft)]">
              {fitGuidance.notFit.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <CTASection
      eyebrow={content.ui.ctaEyebrow}
      title="Ако је радни ток конкретан, обично могу брзо да кажем да ли разговор о изградњи или саветовању има смисла."
      description="Радим пројектну изградњу, ојачавање и саветовање за интерне системе вештачке интелигенције. Кратак опис радног тока, тренутне фазе и кључних ограничења довољан је да се процени да ли ангажман има смисла."
      primary={primaryCta}
      secondary={{ href: '/sr/services/', label: 'Погледајте почетне тачке' }}
    />
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
