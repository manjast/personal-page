---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import { getSiteContent } from '../../config/site';
import { localizedHref } from '../../i18n/routing';

const locale = 'sr';
const content = getSiteContent(locale);
const { siteConfig } = content;
const caseStudies = (await getCollection('case-studies'))
  .filter((entry) => entry.data.locale === locale)
  .sort((left, right) => left.data.order - right.data.order);
const primaryCta = { ...siteConfig.heroPrimaryCta, href: localizedHref(locale, siteConfig.heroPrimaryCta.href) };
---

<BaseLayout
  locale={locale}
  pathname="/sr/work/"
  title="Пројекти интерних AI система"
  description="Прикази интерних AI система изграђених за стварне пословне процесе, са нагласком на то како су постављени, испоручени и шта су дали у пракси."
  pageSchema={[
    {
      '@type': 'CollectionPage',
      '@id': `${siteConfig.siteUrl}/sr/work/#webpage`,
      url: `${siteConfig.siteUrl}/sr/work/`,
      name: 'Пројекти интерних AI система | Стефан Мања',
      description: 'Прикази интерних AI система изграђених за стварне пословне процесе, са нагласком на то како су постављени, испоручени и шта су дали у пракси.',
      author: { '@id': `${siteConfig.siteUrl}/#person` },
      inLanguage: 'sr-Cyrl',
    },
  ]}
>
  <SiteHeader locale={locale} />

  <main id="main">
    <section class="section-space">
      <div class="shell">
        <div class="page-lead">
          <div class="flex flex-wrap items-center gap-3">
            <span class="section-marker">01 / пројекти</span>
            <p class="eyebrow">Пројекти</p>
          </div>
          <h1 class="page-title">
            Како су системи постављени, испоручени и шта су дали у пракси.
          </h1>
          <p class="text-base leading-8 muted-copy">
            Ови прикази су намерно селективни: довољни да покажу проблем, приступ решењу и доказ испоруке, без
            откривања интерног материјала који треба да остане интерни. Тренутни јавни примери долазе из рада у
            Делта Холдингу; спољни клијентски пројекти биће додати када буду могли да се објаве.
          </p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {caseStudies.map((entry) => <CaseStudyCard entry={entry} locale={locale} />)}
        </div>
      </div>
    </section>

    <CTASection
      eyebrow={content.ui.ctaEyebrow}
      title="Ако имате сличан интерни AI процес за који треба развити систем или га довести до стварне употребе, могу да проценим одакле има смисла кренути."
      description="Кратак опис процеса, корисника, тренутне фазе и ограничења обично је довољан да се процени да ли израда система или саветовање имају смисла."
      primary={primaryCta}
      secondary={{ href: '/sr/services/', label: 'Погледајте полазне тачке' }}
    />
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
