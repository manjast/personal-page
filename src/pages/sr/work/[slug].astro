---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import CTASection from '../../../components/CTASection.astro';
import { getSiteContent } from '../../../config/site';
import { caseStudyPath, getAlternatePaths, localizedHref, type Locale } from '../../../i18n/routing';

export async function getStaticPaths() {
  const entries = (await getCollection('case-studies')).filter((entry) => entry.data.locale === 'sr');

  return entries.map((entry) => ({
    params: { slug: entry.data.routeSlug },
    props: { entry },
  }));
}

const locale = 'sr';
const { entry } = Astro.props;
const { Content } = await render(entry);
const content = getSiteContent(locale);
const { siteConfig } = content;
const labels = content.ui.caseStudyDetail;
const detailPath = caseStudyPath(locale, entry.data.routeSlug);
const translatedEntries = (await getCollection('case-studies')).filter(
  (candidate) => candidate.data.translationKey === entry.data.translationKey,
);
const translatedAlternates = translatedEntries.reduce(
  (paths, candidate) => ({
    ...paths,
    [candidate.data.locale]: caseStudyPath(candidate.data.locale, candidate.data.routeSlug),
  }),
  {} as Partial<Record<Locale, string>>,
);
const alternates = {
  ...getAlternatePaths(detailPath),
  ...translatedAlternates,
  'x-default': translatedAlternates.en ?? caseStudyPath('en', entry.data.routeSlug),
};
const canonicalUrl = `${siteConfig.siteUrl}${detailPath}`;
const articleImage = new URL(entry.data.ogImage ?? '/og-default.png', siteConfig.siteUrl).toString();
const primaryCta = { ...siteConfig.heroPrimaryCta, href: localizedHref(locale, siteConfig.heroPrimaryCta.href) };
---

<BaseLayout
  locale={locale}
  pathname={detailPath}
  title={entry.data.title}
  description={entry.data.summary}
  image={entry.data.ogImage}
  ogType="article"
  alternates={alternates}
  pageSchema={[
    {
      '@type': 'Article',
      '@id': `${canonicalUrl}#article`,
      url: canonicalUrl,
      headline: entry.data.title,
      description: entry.data.summary,
      image: articleImage,
      mainEntityOfPage: canonicalUrl,
      author: { '@id': `${siteConfig.siteUrl}/#person` },
      publisher: { '@id': `${siteConfig.siteUrl}/#person` },
      about: entry.data.technologies.map((t: string) => ({ '@type': 'Thing', name: t })),
      inLanguage: 'sr-Cyrl',
    },
  ]}
>
  <SiteHeader locale={locale} alternates={alternates} />

  <main id="main">
    <section class="section-space">
      <div class="shell">
        <a class="ink-link inline-flex min-h-[44px] items-center py-2 text-sm font-semibold transition" href="/sr/work/">
          ← {labels.backLabel}
        </a>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
          <div class="space-y-6">
            <p class="eyebrow">{entry.data.organization}</p>
            <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">{entry.data.title}</h1>
            <p class="text-lg leading-8 muted-copy">{entry.data.summary}</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.technologies.map((technology) => <span class="rounded-full border border-[color:var(--rule)] bg-white/55 px-3 py-1 text-[0.75rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">{technology}</span>)}
            </div>
          </div>

          <div class="panel panel-dark p-6">
            <div class="accent-bar"></div>
            <div class="space-y-5 text-sm">
              <div class="border-t border-white/10 pt-4 first:border-t-0 first:pt-0">
                <p class="metric-label">{labels.workContextLabel}</p>
                <p class="mt-2 leading-7 text-[color:rgba(247,241,232,0.82)]">{entry.data.workContext}</p>
              </div>
              <div class="border-t border-white/10 pt-4">
                <p class="metric-label">{entry.data.signalLabel ?? labels.outcomeSignalLabel}</p>
                <p class="mt-2 leading-7 text-[color:rgba(247,241,232,0.82)]">{entry.data.outcome}</p>
              </div>
            </div>
          </div>
        </div>

        <article class="content-body mt-12 max-w-3xl border-t border-[color:var(--rule)] pt-8">
          <Content />
        </article>
      </div>
    </section>

    <CTASection
      eyebrow={content.ui.ctaEyebrow}
      title="За сличан AI процес могу брзо да проценим да ли има смисла израда система, стабилизација или саветодавни рад."
      description="Најбоља почетна тачка је кратак опис процеса, власника, тренутне фазе и онога што би морало да буде поуздано да би систем био користан."
      primary={primaryCta}
      secondary={{ href: '/sr/services/', label: 'Погледајте полазне тачке' }}
    />
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
