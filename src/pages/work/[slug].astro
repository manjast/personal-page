---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CTASection from '../../components/CTASection.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'case-studies'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  pathname={`/work/${entry.slug}/`}
  title={entry.data.title}
  description={entry.data.summary}
>
  <SiteHeader />

  <main>
    <section class="section-space">
      <div class="shell">
        <a class="text-sm font-semibold text-stone-950 transition hover:text-stone-700" href="/work">
          ← Back to selected work
        </a>

        <div class="mt-8 max-w-4xl space-y-6">
          <p class="eyebrow">{entry.data.client}</p>
          <h1 class="text-4xl font-semibold tracking-tight text-stone-950 sm:text-5xl">{entry.data.title}</h1>
          <p class="text-lg leading-8 text-stone-700">{entry.data.summary}</p>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="panel panel-light p-5">
              <p class="text-sm font-semibold text-stone-950">Client context</p>
              <p class="mt-2 text-sm leading-7 text-stone-600">{entry.data.clientContext}</p>
            </div>
            <div class="panel panel-light p-5">
              <p class="text-sm font-semibold text-stone-950">Outcome signal</p>
              <p class="mt-2 text-sm leading-7 text-stone-600">{entry.data.outcome}</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            {entry.data.technologies.map((technology) => <span class="rounded-full border border-stone-200 px-3 py-1 text-xs text-stone-600">{technology}</span>)}
          </div>
        </div>

        <article class="content-body mt-12 max-w-4xl">
          <Content />
        </article>
      </div>
    </section>

    <CTASection
      title="If your team has a similar workflow, I can usually tell quickly whether it needs a build, hardening pass, or scoped advisory help."
      description="The best starting point is a short description of the workflow, the owner, the current stage, and what would need to be trustworthy for the system to be useful."
      primary={siteConfig.heroPrimaryCta}
      secondary={{ href: '/services', label: 'See project shapes' }}
    />
  </main>

  <SiteFooter />
</BaseLayout>
