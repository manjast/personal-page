---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import CTASection from '../../components/CTASection.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'case-studies'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  pathname={`/work/${entry.slug}/`}
  title={entry.data.title}
  description={entry.data.summary}
  image={entry.data.ogImage}
>
  <SiteHeader />

  <main>
    <section class="section-space">
      <div class="shell">
        <a class="ink-link text-sm font-semibold transition" href="/work">
          ← Back to selected work
        </a>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
          <div class="space-y-6">
            <p class="eyebrow">{entry.data.client}</p>
            <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">{entry.data.title}</h1>
            <p class="text-lg leading-8 muted-copy">{entry.data.summary}</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.technologies.map((technology) => <span class="rounded-full border border-[color:var(--rule)] bg-white/55 px-3 py-1 text-[0.75rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">{technology}</span>)}
            </div>
          </div>

          <div class="panel panel-dark p-6">
            <div class="accent-bar"></div>
            <div class="space-y-5 text-sm">
              <div class="border-t border-white/10 pt-4 first:border-t-0 first:pt-0">
                <p class="metric-label">Client context</p>
                <p class="mt-2 leading-7 text-[color:rgba(247,241,232,0.82)]">{entry.data.clientContext}</p>
              </div>
              <div class="border-t border-white/10 pt-4">
                <p class="metric-label">Outcome signal</p>
                <p class="mt-2 leading-7 text-[color:rgba(247,241,232,0.82)]">{entry.data.outcome}</p>
              </div>
            </div>
          </div>
        </div>

        <article class="content-body mt-12 max-w-4xl border-t border-[color:var(--rule)] pt-8">
          <Content />
        </article>
      </div>
    </section>

    <CTASection
      title="If your team has a similar workflow, I can usually tell quickly whether it needs a build, hardening pass, or scoped advisory help."
      description="The best starting point is a short description of the workflow, the owner, the current stage, and what would need to be trustworthy for the system to be useful."
      primary={siteConfig.heroPrimaryCta}
      secondary={{ href: '/services', label: 'See project shapes' }}
    />
  </main>

  <SiteFooter />
</BaseLayout>
